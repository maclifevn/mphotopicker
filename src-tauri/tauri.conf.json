{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MPhotoPicker",
  "version": "1.0.0",
  "identifier": "cloud.maclife.mphotopicker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MPhotoPicker — Lọc & chép ảnh theo tên",
        "width": 1180,
        "height": 760,
        "minWidth": 920,
        "minHeight": 600,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
